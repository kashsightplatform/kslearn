# Website - NOT pushed to GitHub
website/

# Environment variables (Firebase creds for custom projects)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# ── JSON files: BLOCK all by default ──
# User config, progress, cache — never commit
*.json
# Exceptions: sample/template JSONs used for docs & distribution
!data/kslearn_package.json
!data/kslearn_brain.json
!data/ksl/hierarchical_sample.json

# ── KSL files: ALLOW all ──
# KSL packages are the distributable content — commit them
!*.ksl

# User data (don't push personal progress)
data/config/
data/chat_history.*
data/chat_settings.*
data/knowledge_brain.*
data/progress.*
data/brain/

# Generated files
learnquest/

# Logs
*.log

# Firebase hosting cache
.firebase/hosting.*.cache

# Temporary
tmp/
temp/
*.tmp
